# Copy to .env and adjust. When running via marketplace-stack, these are set by Docker Compose.
# DB URL, S3/MinIO (endpoint/access/secret/bucket), admin credentials — без секретов в репо.
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketplace
APP_JWT_SECRET_KEY=changeme-secret-key
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRES_MINUTES=60
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=admin123
APP_MINIO_ENDPOINT=localhost:9000
APP_MINIO_ACCESS_KEY=minioadmin
APP_MINIO_SECRET_KEY=minioadmin
APP_MINIO_SECURE=false
APP_MINIO_BUCKET_PRODUCTS=products
# CORS: при необходимости задать через переменные и использовать в main.py (сейчас origins захардкожены для localhost).
